# Supabase Configuration
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Authentication (enable/disable features)
ENABLE_AUTH=true
ENABLE_SOCIAL_AUTH=true
ENABLE_STORAGE=true
ENABLE_EMAIL_VERIFICATION=true

# Social Auth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_EXPIRY=7d

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@manifex.com
SMTP_FROM_NAME=Manifex

# Email Verification & Password Reset
EMAIL_VERIFICATION_EXPIRY=86400
PASSWORD_RESET_EXPIRY=3600
PASSWORD_RESET_URL=https://yourfrontend.com/reset-password

# Server Configuration
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Initial Seeding (Optional)
ADMIN_EMAIL=admin@manifex.com
ADMIN_PASSWORD=Admin@123456

# Logging
LOG_LEVEL=info

# Storage Configuration
STORAGE_BUCKET_NAME=user-uploads
MAX_FILE_SIZE=5242880
